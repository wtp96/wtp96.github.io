---
import Base from '@/layouts/Base.astro';
import PostList from '@/components/PostList.astro';
import Pagination from '@/components/Pagination.astro';
import { getAllPosts, getPostsByCategory, isValidCategory } from '@/utils/posts';
import { CATEGORIES, CATEGORY_SLUGS, POSTS_PER_PAGE } from '@/consts';

export async function getStaticPaths() {
  const allPosts = await getAllPosts();
  const paths: { params: { category: string; page: string } }[] = [];
  for (const category of CATEGORY_SLUGS) {
    const posts = getPostsByCategory(allPosts, category);
    const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
    for (let i = 2; i <= totalPages; i++) {
      paths.push({ params: { category, page: i.toString() } });
    }
  }
  return paths;
}

const { category, page } = Astro.params;
if (!isValidCategory(category)) {
  return Astro.redirect('/404/');
}

const currentPage = Number(page);
const allPosts = await getAllPosts();
const categoryPosts = getPostsByCategory(allPosts, category);
const totalPages = Math.ceil(categoryPosts.length / POSTS_PER_PAGE);
const posts = categoryPosts.slice((currentPage - 1) * POSTS_PER_PAGE, currentPage * POSTS_PER_PAGE);
const categoryLabel = CATEGORIES[category] || category;
---

<Base title={`${categoryLabel} - 第 ${currentPage} 頁`} centered={false}>
  <h1 class="text-2xl font-semibold mt-8 mb-8">{categoryLabel}</h1>
  <PostList posts={posts} />
  <Pagination currentPage={currentPage} totalPages={totalPages} basePath={`/${category}/`} />
</Base>
