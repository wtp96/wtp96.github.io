---
import Base from '@/layouts/Base.astro';
---

<Base title="404" description="找不到頁面">
  <div class="py-20 text-center">
    <h1 class="text-4xl font-semibold mb-4">404</h1>
    <p class="text-text-secondary mb-8">這裡什麼都沒有。</p>
    <a href="/" class="inline-block px-4 py-2 rounded-md bg-accent text-white hover:opacity-90 transition-opacity">
      回到首頁
    </a>
  </div>
</Base>
