<script>
  document.querySelectorAll('pre').forEach((pre) => {
    const button = document.createElement('button');
    button.type = 'button';
    button.className = 'copy-code absolute top-2 right-2 px-2 py-1 text-xs rounded bg-bg border border-border text-text-secondary hover:text-text opacity-0 transition-opacity';
    button.textContent = 'Copy';
    pre.classList.add('group');
    pre.appendChild(button);

    pre.addEventListener('mouseenter', () => button.classList.remove('opacity-0'));
    pre.addEventListener('mouseleave', () => button.classList.add('opacity-0'));

    button.addEventListener('click', async () => {
      const code = pre.querySelector('code');
      if (!code) return;
      await navigator.clipboard.writeText(code.textContent || '');
      button.textContent = 'Copied';
      setTimeout(() => (button.textContent = 'Copy'), 1500);
    });
  });
</script>
