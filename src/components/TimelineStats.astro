---
import { SITE } from '@/consts';
import type { CollectionEntry } from 'astro:content';
import { getDayOfYear, getYearProgress, getTodayProgress } from '@/utils/posts';

type Props = {
  posts: CollectionEntry<'posts'>[];
  currentView?: 'relaxed' | 'dense' | 'overview';
};

const { posts, currentView = 'relaxed' } = Astro.props;
const now = new Date();
const totalPosts = posts.length;
const currentYear = now.getFullYear().toString();
const yearPosts = posts.filter((p) => p.data.date.getFullYear().toString() === currentYear).length;
---

<section class="mb-12">
  <div class="flex items-start justify-between mb-8">
    <h1 class="text-sm font-medium text-text-secondary tracking-wide">時間線</h1>
    <div class="flex items-center gap-1 text-sm">
      <a
        href="/timeline/?view=relaxed"
        class:list={[
          'px-2 py-1 rounded-md transition-colors',
          currentView === 'relaxed' ? 'text-accent bg-bg-elevated' : 'text-text-secondary hover:text-text hover:bg-bg-elevated',
        ]}
      >
        舒
      </a>
      <a
        href="/timeline/?view=dense"
        class:list={[
          'px-2 py-1 rounded-md transition-colors',
          currentView === 'dense' ? 'text-accent bg-bg-elevated' : 'text-text-secondary hover:text-text hover:bg-bg-elevated',
        ]}
      >
        密
      </a>
      <a
        href="/timeline/?view=overview"
        class:list={[
          'px-2 py-1 rounded-md transition-colors',
          currentView === 'overview' ? 'text-accent bg-bg-elevated' : 'text-text-secondary hover:text-text hover:bg-bg-elevated',
        ]}
      >
        概覽
      </a>
      <button
        type="button"
        id="timeline-search-trigger"
        class="flex items-center gap-1 px-2 py-1 rounded-md text-text-secondary hover:text-text hover:bg-bg-elevated transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.031 16.617 22.314 20.899 20.899 22.314 16.617 18.031A9.96 9.96 0 0 1 11 20C6.032 20 2 15.968 2 11S6.032 2 11 2s9 4.032 9 9a9.96 9.96 0 0 1-1.969 5.617Zm-2.006-.042A7.96 7.96 0 0 0 19 11c0-4.411-3.589-8-8-8s-8 3.589-8 8 3.589 8 8 8a7.96 7.96 0 0 0 5.575-2.329Z" />
        </svg>
        <span>搜索</span>
      </button>
    </div>
  </div>

  <div class="space-y-6">
    <div class="flex items-baseline gap-3">
      <span class="text-6xl sm:text-7xl font-light tracking-tight text-text">{totalPosts}</span>
      <span class="text-sm text-text-secondary">篇，再接再厲</span>
    </div>

    <div class="flex flex-wrap items-end gap-8 sm:gap-12">
      <div class="flex flex-col gap-1">
        <span class="text-3xl sm:text-4xl font-light text-accent">{getDayOfYear(now)}</span>
        <span class="text-xs text-text-secondary">今年第幾天</span>
      </div>
      <div class="flex flex-col gap-1">
        <span class="text-3xl sm:text-4xl font-light text-text">
          {getYearProgress(now).toFixed(0)}
          <span class="text-lg">%</span>
        </span>
        <span class="text-xs text-text-secondary">年度進度</span>
      </div>
      <div class="flex flex-col gap-1">
        <span class="text-3xl sm:text-4xl font-light text-text">
          {getTodayProgress(now).toFixed(2)}
          <span class="text-lg">%</span>
        </span>
        <span class="text-xs text-text-secondary">今日進度</span>
      </div>
    </div>

    <p class="text-sm text-text-secondary">{SITE.description}</p>
  </div>
</section>

<script is:inline>
  document.getElementById('timeline-search-trigger')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-search'));
  });
</script>
